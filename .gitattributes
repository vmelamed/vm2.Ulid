# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF line endings
*.sh text eol=lf

# Windows scripts should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Explicitly declare text files you want to always be normalized and end the lines with a line-feed (works for both Linux and Windows)
*.cs text eol=lf diff=csharp
*.csproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf

# NuGet lockfiles are generated — never merge them by hand. The 'nugetlock' merge driver (defined locally by
# repo-setup.sh as merge.nugetlock.*) takes the incoming side; regenerate with 'dotnet restore --force-evaluate'.
# Without the driver configured, git falls back to the normal text merge.
packages.lock.json merge=nugetlock

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
